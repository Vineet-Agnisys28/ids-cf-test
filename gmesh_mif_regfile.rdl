    desc = "These registers state the decrement value for the TxnID tracker's counter.
            For each CHI RSP opcode, the tracker counter can take one of
            two decrement values according to the dec_value_sel, determine per REQ opcode";
    default sw=rw;
    default hw=r;
    field {
      desc = "Counter dec value, per CHI RSP Opcode";
    } dec_value0 [1:0] = 2'b0;
    field {
      desc = "Counter dec value, per CHI RSP Opcode";
    } dec_value1 [3:2] = 2'b0;
  }cfg_chi_rsp_op2dec[64];


