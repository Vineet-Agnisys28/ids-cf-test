/*

           String can be as one from the followings

Generates appropriate coverage code in the output  |        "a, b, f, f.rd, f.wr, b.rd, b.wr,on, off"

                                       a                -        Generates CG cg_addr

                                       f                -        Generates CG rd_cg_vals & wr_cg_vals

                                               f.rd        -        Generates CG rd_cg_vals

                                               f.wr        -        Generates CG wr_cg_vals

                                       b                -        Generates CG rd_cg_bits & wr_cg_bits

                                               b.rd        -        Generates CG rd_cg_bits

                                               b.wr        -        Generates CG wr_cg_bits

*/



property coverage_per_instance { type = boolean; component = addrmap|regfile|reg; };


