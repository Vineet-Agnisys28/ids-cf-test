    assign csr_slc_rqm_cfg_rqm_cbusy_mif_rd_data  = csr_slc_rqm_cfg_rqm_cbusy_mif_rd_valid ? {csr_slc_rqm_cfg_rqm_cbusy_mif_aging_period_q,csr_slc_rqm_cfg_rqm_cbusy_mif_busy_factor_q,csr_slc_rqm_cfg_rqm_cbusy_mif_window_size_q,csr_slc_rqm_cfg_rqm_cbusy_mif_max_out_q} : 32'd0;

