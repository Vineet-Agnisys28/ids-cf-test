    generate

    if (HAS_MIF_HASH)
        begin : csr_slc_rqm_cfg_rqm_target_mif_table_index

            genvar csr_slc_rqm_cfg_rqm_target_mif_table_index_i;
            for( csr_slc_rqm_cfg_rqm_target_mif_table_index_i = 0; csr_slc_rqm_cfg_rqm_target_mif_table_index_i < 8; csr_slc_rqm_cfg_rqm_target_mif_table_index_i = csr_slc_rqm_cfg_rqm_target_mif_table_index_i + 1)
            begin : csr_slc_rqm_cfg_rqm_target_mif_table_index_gen

                //----------------------------------------------------------------------------------------------------
                // REGISTER      :  CSR_SLC_RQM_CFG_RQM_TARGET_MIF_TABLE_INDEX
                // ADDRESS       :  block_offset +'h14 + csr_slc_rqm_cfg_rqm_target_mif_table_index_i * 'h4 + 'h310        WIDTH : 32
                // HW ACCESS     :  RO
                // SW ACCESS     :  READ-WRITE
                //
                // FIELDS   :
                //     5:0 : threshold  ( SW : RW HW : RO )
                //-----------------------------------------------------------------------------
                /* DESCRIPTION  :  NA
                */
                assign csr_slc_rqm_cfg_rqm_target_mif_table_index_wr_valid[csr_slc_rqm_cfg_rqm_target_mif_table_index_i] = csr_slc_rqm_cfg_rqm_target_mif_table_index_decode[csr_slc_rqm_cfg_rqm_target_mif_table_index_i] && wr_stb ;
                assign csr_slc_rqm_cfg_rqm_target_mif_table_index_offset[csr_slc_rqm_cfg_rqm_target_mif_table_index_i] = block_offset +'h14 + csr_slc_rqm_cfg_rqm_target_mif_table_index_i * 'h4 + 'h310;
                assign csr_slc_rqm_cfg_rqm_target_mif_table_index_decode[csr_slc_rqm_cfg_rqm_target_mif_table_index_i] = (address[addr_width-1 : 0] == csr_slc_rqm_cfg_rqm_target_mif_table_index_offset[csr_slc_rqm_cfg_rqm_target_mif_table_index_i][addr_width-1 : 0]) ? 1'b1 : 1'b0;
                assign csr_slc_rqm_cfg_rqm_target_mif_table_index_rd_valid[csr_slc_rqm_cfg_rqm_target_mif_table_index_i] = csr_slc_rqm_cfg_rqm_target_mif_table_index_decode[csr_slc_rqm_cfg_rqm_target_mif_table_index_i] && rd_stb ;
                assign csr_slc_rqm_cfg_rqm_target_mif_table_index_enb[csr_slc_rqm_cfg_rqm_target_mif_table_index_i] = csr_slc_rqm_cfg_rqm_target_mif_table_index_wr_valid[csr_slc_rqm_cfg_rqm_target_mif_table_index_i];

                //----------------------------------------------------------------------------
                // FIELD  : THRESHOLD
                // HW ACCESS  : RO                          WIDTH : 6
                // SW ACCESS  : RW                          OFFSET : 0
                //-----------------------------------------------------------------
                /*DESCRIPTION    : The threshold that determines the TableIndex which is used as an index to a lookup table of the target MI-F EID. The table index is calulated as follows (A = {SLC[0],SLC[6:2]}) : if A<TH0: TableIndex = 0 elif A<TH1: TableIndex =1 elif A<TH2: TableIndex = 2 elif A<TH3: TableIndex = 3 elif A<TH4: TableIndex = 4 elif A<TH5: TableIndex = 5 elif A<TH6: TableIndex = 6 elif A<TH7: TableIndex = 7 else: TableIndex = 8 The thresholds TH0-TH7 shall be set according to the following table and the number of active MI-Fs: TH Idx Eight Active MI-Fs Nine Active MI-Fs 0 7 6 1 14 12 2 21 19 3 28 25 4 39 35 5 46 41 6 53 48 7 60 54
                */

                always @(posedge clk or negedge reset_l)  begin
                if (!reset_l)
                    begin
                        csr_slc_rqm_cfg_rqm_target_mif_table_index_threshold_q[csr_slc_rqm_cfg_rqm_target_mif_table_index_i] <= csr_slc_rqm_cfg_rqm_target_mif_table_index_threshold_param[csr_slc_rqm_cfg_rqm_target_mif_table_index_i];
                    end
                else
                    begin
                    if (csr_slc_rqm_cfg_rqm_target_mif_table_index_wr_valid[csr_slc_rqm_cfg_rqm_target_mif_table_index_i])     //THRESHOLD : SW Write
                        begin
                            csr_slc_rqm_cfg_rqm_target_mif_table_index_threshold_q[csr_slc_rqm_cfg_rqm_target_mif_table_index_i] <= (wr_data [5 : 0]  & reg_enb  [5 : 0] ) | (csr_slc_rqm_cfg_rqm_target_mif_table_index_threshold_q[csr_slc_rqm_cfg_rqm_target_mif_table_index_i] & (~reg_enb  [5 : 0] ));
                        end
                    end
                end //end always

                assign csr_slc_rqm_cfg_rqm_target_mif_table_index_threshold_r[csr_slc_rqm_cfg_rqm_target_mif_table_index_i] = csr_slc_rqm_cfg_rqm_target_mif_table_index_threshold_q[csr_slc_rqm_cfg_rqm_target_mif_table_index_i]; // Field : THRESHOLD
                assign csr_slc_rqm_cfg_rqm_target_mif_table_index_rd_data [csr_slc_rqm_cfg_rqm_target_mif_table_index_i] = csr_slc_rqm_cfg_rqm_target_mif_table_index_rd_valid[csr_slc_rqm_cfg_rqm_target_mif_table_index_i] ? {26'h0, csr_slc_rqm_cfg_rqm_target_mif_table_index_threshold_q[csr_slc_rqm_cfg_rqm_target_mif_table_index_i]} : 32'd0;

            end //csr_slc_rqm_cfg_rqm_target_mif_table_index
            assign csr_slc_rqm_cfg_rqm_target_mif_table_index_emptyAddress_p = 0 ;
            assign csr_slc_rqm_cfg_rqm_target_mif_table_index_rd_data_wire  = csr_slc_rqm_cfg_rqm_target_mif_table_index_rd_data[0] | csr_slc_rqm_cfg_rqm_target_mif_table_index_rd_data[1] | csr_slc_rqm_cfg_rqm_target_mif_table_index_rd_data[2] | csr_slc_rqm_cfg_rqm_target_mif_table_index_rd_data[3] | csr_slc_rqm_cfg_rqm_target_mif_table_index_rd_data[4] | csr_slc_rqm_cfg_rqm_target_mif_table_index_rd_data[5] | csr_slc_rqm_cfg_rqm_target_mif_table_index_rd_data[6] | csr_slc_rqm_cfg_rqm_target_mif_table_index_rd_data[7] ;
        end
    else
        begin
            assign csr_slc_rqm_cfg_rqm_target_mif_table_index_emptyAddress_p_l = block_offset + 'h324 ;
            assign csr_slc_rqm_cfg_rqm_target_mif_table_index_emptyAddress_p_h = block_offset + 'h343 ;
            assign csr_slc_rqm_cfg_rqm_target_mif_table_index_emptyAddress_p = ((address[addr_width -1 : 0] >= csr_slc_rqm_cfg_rqm_target_mif_table_index_emptyAddress_p_l[addr_width - 1 : 0]) && (address[addr_width -1 : 0] <= csr_slc_rqm_cfg_rqm_target_mif_table_index_emptyAddress_p_h[addr_width - 1 : 0])) ? 1'b1 : 1'b0 ;
            assign csr_slc_rqm_cfg_rqm_target_mif_table_index_rd_data_wire = 0 ;

        end

    endgenerate

    generate

    if (HAS_MIF_HASH)
        begin : csr_slc_rqm_cfg_rqm_table_index_to_mif

            genvar csr_slc_rqm_cfg_rqm_table_index_to_mif_i;
            for( csr_slc_rqm_cfg_rqm_table_index_to_mif_i = 0; csr_slc_rqm_cfg_rqm_table_index_to_mif_i < 9; csr_slc_rqm_cfg_rqm_table_index_to_mif_i = csr_slc_rqm_cfg_rqm_table_index_to_mif_i + 1)
            begin : csr_slc_rqm_cfg_rqm_table_index_to_mif_gen

                //----------------------------------------------------------------------------------------------------
                // REGISTER      :  CSR_SLC_RQM_CFG_RQM_TABLE_INDEX_TO_MIF
                // ADDRESS       :  block_offset +'h14 + csr_slc_rqm_cfg_rqm_table_index_to_mif_i * 'h4 + 'h330        WIDTH : 32
                // HW ACCESS     :  RO
                // SW ACCESS     :  READ-WRITE
                //
                // FIELDS   :
                //     0:9 : eid  ( SW : RW HW : RO )
                //-----------------------------------------------------------------------------
                /* DESCRIPTION  :  NA
                */
                assign csr_slc_rqm_cfg_rqm_table_index_to_mif_wr_valid[csr_slc_rqm_cfg_rqm_table_index_to_mif_i] = csr_slc_rqm_cfg_rqm_table_index_to_mif_decode[csr_slc_rqm_cfg_rqm_table_index_to_mif_i] && wr_stb ;
                assign csr_slc_rqm_cfg_rqm_table_index_to_mif_offset[csr_slc_rqm_cfg_rqm_table_index_to_mif_i] = block_offset +'h14 + csr_slc_rqm_cfg_rqm_table_index_to_mif_i * 'h4 + 'h330;
                assign csr_slc_rqm_cfg_rqm_table_index_to_mif_decode[csr_slc_rqm_cfg_rqm_table_index_to_mif_i] = (address[addr_width-1 : 0] == csr_slc_rqm_cfg_rqm_table_index_to_mif_offset[csr_slc_rqm_cfg_rqm_table_index_to_mif_i][addr_width-1 : 0]) ? 1'b1 : 1'b0;
                assign csr_slc_rqm_cfg_rqm_table_index_to_mif_rd_valid[csr_slc_rqm_cfg_rqm_table_index_to_mif_i] = csr_slc_rqm_cfg_rqm_table_index_to_mif_decode[csr_slc_rqm_cfg_rqm_table_index_to_mif_i] && rd_stb ;
                assign csr_slc_rqm_cfg_rqm_table_index_to_mif_enb[csr_slc_rqm_cfg_rqm_table_index_to_mif_i] = csr_slc_rqm_cfg_rqm_table_index_to_mif_wr_valid[csr_slc_rqm_cfg_rqm_table_index_to_mif_i];

                //----------------------------------------------------------------------------
                // FIELD  : EID
                // HW ACCESS  : RO                          WIDTH : 10
                // SW ACCESS  : RW                          OFFSET : 0
                //-----------------------------------------------------------------
                /*DESCRIPTION    : A lookup table of the target MI-F EID, the index to the lookup table is the table index calculated based on cfg_rqm_target_mif_table_index_threshold. The lookup table should be configured with the active MI-F EID in order from left to right. The EID of the leftmost active MI-F should be written to the first entry of the table (MI-F0 EID). If there are 9 active MI-Fs then the EID of the rightmost active MI-F is written to the last entry (MI-F8 EID) and if there are 8 active MI-F the EID of the rightmost active MI-F is written to the MI-F7 EID entry.
                */

                always @(posedge clk or negedge reset_l)  begin
                if (!reset_l)
                    begin
                        csr_slc_rqm_cfg_rqm_table_index_to_mif_eid_q[csr_slc_rqm_cfg_rqm_table_index_to_mif_i] <= 'd0;
                    end
                else
                    begin
                    if (csr_slc_rqm_cfg_rqm_table_index_to_mif_wr_valid[csr_slc_rqm_cfg_rqm_table_index_to_mif_i])     //EID : SW Write
                        begin
                            csr_slc_rqm_cfg_rqm_table_index_to_mif_eid_q[csr_slc_rqm_cfg_rqm_table_index_to_mif_i] <= (wr_data [(EID_WIDTH - 1)  :  0]  & reg_enb  [(EID_WIDTH - 1)  :  0] ) | (csr_slc_rqm_cfg_rqm_table_index_to_mif_eid_q[csr_slc_rqm_cfg_rqm_table_index_to_mif_i] & (~reg_enb  [(EID_WIDTH - 1)  :  0] ));
                        end
                    end
                end //end always

                assign csr_slc_rqm_cfg_rqm_table_index_to_mif_eid_r[csr_slc_rqm_cfg_rqm_table_index_to_mif_i] = csr_slc_rqm_cfg_rqm_table_index_to_mif_eid_q[csr_slc_rqm_cfg_rqm_table_index_to_mif_i]; // Field : EID
                assign csr_slc_rqm_cfg_rqm_table_index_to_mif_rd_data [csr_slc_rqm_cfg_rqm_table_index_to_mif_i] = csr_slc_rqm_cfg_rqm_table_index_to_mif_rd_valid[csr_slc_rqm_cfg_rqm_table_index_to_mif_i] ? {{(32-(EID_WIDTH - 1) -1){1'b0}}, csr_slc_rqm_cfg_rqm_table_index_to_mif_eid_q[csr_slc_rqm_cfg_rqm_table_index_to_mif_i]} : 32'd0;

            end //csr_slc_rqm_cfg_rqm_table_index_to_mif
