    assign csr_slc_rqm_cfg_rqm_slc_hashing_override_rd_valid = csr_slc_rqm_cfg_rqm_slc_hashing_override_decode && rd_stb ;
    assign csr_slc_rqm_cfg_rqm_slc_hashing_override_enb = csr_slc_rqm_cfg_rqm_slc_hashing_override_wr_valid;

