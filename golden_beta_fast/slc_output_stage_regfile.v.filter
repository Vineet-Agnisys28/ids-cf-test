    assign csr_slc_rqm_cfg_rqm_cbusy_use_mif_wr_valid = csr_slc_rqm_cfg_rqm_cbusy_use_mif_decode && wr_stb ;
    assign csr_slc_rqm_cfg_rqm_cbusy_use_mif_offset = block_offset +'hCC+'h14;
    assign csr_slc_rqm_cfg_rqm_cbusy_use_mif_decode = (address[addr_width-1 : 0] == csr_slc_rqm_cfg_rqm_cbusy_use_mif_offset[addr_width-1 : 0]) ? 1'b1 : 1'b0;
    assign csr_slc_rqm_cfg_rqm_cbusy_use_mif_rd_valid = csr_slc_rqm_cfg_rqm_cbusy_use_mif_decode && rd_stb ;
    assign csr_slc_rqm_cfg_rqm_cbusy_use_mif_enb = csr_slc_rqm_cfg_rqm_cbusy_use_mif_wr_valid;

