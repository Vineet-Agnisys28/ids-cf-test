`include "gmesh_telemetry_agent_regfile.rdl"

`ifndef _GMESH_TELEMETRY_BW_REGFILE_
`define _GMESH_TELEMETRY_BW_REGFILE_

regfile gmesh_telemetry_bw_regfile #(
  longint unsigned INTERVAL_WINDOW_CNT_WIDTH  = 16,
  longint unsigned NUM_TELEMETRY_COUNTERS     = 8,
  longint unsigned ADDR_WIDTH                 = 48,
  longint unsigned AGENT_ID_WIDTH             = 9
)
  {
  name = "gmesh_telemetry_bw_regfile";
  desc = "Telemetry BW agent FW interface";
  default sw = rw;
  default hw = r;

  gmesh_telemetry_agent_regfile #(
    .INTERVAL_WINDOW_CNT_WIDTH (INTERVAL_WINDOW_CNT_WIDTH),
    .NUM_TELEMETRY_COUNTERS    (NUM_TELEMETRY_COUNTERS   ),
    .ADDR_WIDTH                (ADDR_WIDTH               ),
    .AGENT_ID_WIDTH            (AGENT_ID_WIDTH           ),
    .HAS_COUNTER_FILTER        (1'b1                     ),
    .HAS_RATIO_CALCULATION     (1'b1                     ),
    .HAS_APB_INTERFACE         (1'b0                     ),
    .HAS_ATTRIBUTE_FILTERING   (1'b1                     ))
  gmesh_telemetry_bw_agent;

};
`endif
